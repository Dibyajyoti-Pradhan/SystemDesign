# SQLite path. Default is fine.
DATABASE_URL=./data/study.db

# AI features (topic generation, card generation, mock interview) shell out to
# the `claude` CLI and use whatever auth Claude Code is logged in with —
# typically your Pro/Max subscription. No API key needed.
#
# If you'd rather use a pay-per-token API key instead of the subscription, set:
# ANTHROPIC_API_KEY=sk-ant-...
